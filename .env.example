# ── Email Notification Settings ──────────────────────────────────────────────
# When a demo request is submitted, Speedchain AI sends a notification email to
# Satyamsinghal@speedchain.io.  Configure ONE of the two options below.

# Option A — Gmail (easiest)
# Use an App Password (not your normal Gmail password).
# https://support.google.com/accounts/answer/185833
GMAIL_USER=your-gmail-account@gmail.com
GMAIL_PASS=your-gmail-app-password

# Option B — Custom SMTP (e.g. Outlook, Postmark, SendGrid, cPanel mail, etc.)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@speedchain.io

# ── Database (optional) ───────────────────────────────────────────────────────
# Leave unset to use in-memory storage (data lost on restart).
# DATABASE_URL=postgres://user:password@host:5432/dbname
